{
  "name": "volcanic-backend-sample",
  "version": "2.3.0",
  "description": "Volcanic Backend Sample",
  "main": "dist/index.js",
  "author": "Volcanic Minds <developers@volcanicminds.com> (https://volcanicminds.com)",
  "maintainers": [
    "Developers <developers@volcanicminds.com> (https://volcanicminds.com)"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "preprod": "npm run build",
    "prod": "cd dist && node index.js",
    "server": "cd dist && node index.js",
    "start:prod": "cd dist && node --env-file ../.env index.js",
    "start": "tsx --env-file .env index.ts",
    "dev": "tsx watch --env-file .env index.ts",
    "reset": "npm install && npm update && npm run build",
    "upgrade-deps": "npx npm-check-updates -u",
    "test": "npm run test:full",
    "test:full": "cross-env PORT=2231 NODE_ENV=memory BROWSER=false mocha --loader=tsx ./test/index.spec.ts -t 100000",
    "test:demo": "MOCHA_SKIP_TASK=unit,e2e npm run test:full",
    "test:e2e": "MOCHA_SKIP_TASK=unit,demo npm run test:full",
    "test:unit": "MOCHA_SKIP_TASK=demo,e2e npm run test:full",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "check-all": "npm run lint && npm run type-check"
  },
  "dependencies": {
    "@volcanicminds/backend": "^2.3.2",
    "@volcanicminds/tools": "^0.1.0",
    "@volcanicminds/typeorm": "^2.3.3",
    "axios": "^1.14.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.12.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "expect": "^30.3.0",
    "globals": "^17.4.0",
    "mocha": "^11.7.5",
    "npm-upgrade": "^3.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  },
  "engines": {
    "node": ">=24"
  }
}
